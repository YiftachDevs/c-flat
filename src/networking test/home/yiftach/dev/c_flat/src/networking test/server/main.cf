import std/net.cf;
import std/error.cf;
import std/io.cf;
import std/system.cf;
import std/time.cf;

fun main() -> i32 {
    let result = program();
    let res = if result.is_ok() {
        0
    } else {
        println(&result.unwrap_err().msg);
        -1
    };
    print("heap count: ");
    println(&(*mem:heap_count()).to_string());
    res
}

fun program() -> Result<()> {
    let listener = TCP_Listener:listen(8080, 1)?;
    println("Listening...");
    loop {
        let opt_client = listener.accept();
        if opt_client.is_none() {
            sleep(0.1);
            skip;
        }
        println("Accepted");
        let client = opt_client.unwrap();
        let text = client.recv_text(6)?;
        println(&text);
        break;
    }
    Result<()>:ok(())
}
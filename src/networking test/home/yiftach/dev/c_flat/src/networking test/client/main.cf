import std/net.cf;
import std/io.cf;
import std/system.cf;

fun main() -> i32 {
    let result = program();
    let res = if result.is_ok() {
        0
    } else {
        println(&result.unwrap_err().msg);
        -1
    };
    print("heap count: ");
    println(&(*mem:heap_count()).to_string());
    res
}

fun program() -> Result<()> {
    println("- Welcome to the C-Flat Compiler -\n");

    print("Enter environment folder: ");
    let env_folder = readln();
    let mut file_name = "{}/main.cf".format(&[&env_folder]);
    if !File:exists(&file_name) {
        let mut err_msg = "Error: File '{}' does not exist".format(&[&file_name]);
        return Result<()>:err(Error{ err_msg });
    }
    let file = File:open(&file_name)?;

    // println("Connecting to server...");
    // let socket = TCP_Socket:connect("127.0.0.1", 8080)?;
    // println("Connected.");
    
    let mut iter = env_folder.iter().rev();
    let folder_name = iter.until('/').skip(1).as_slice();
    set_working_dir(iter.as_slice());
    system(&"zip -r c_flat_env_temp.zip \"{}\"".format(&[iter.as_slice()]));

    println("Done.");
    Result<()>:ok(())
}
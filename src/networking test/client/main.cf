import std/net.cf;
import std/io.cf;

fun main() -> i32 {
    let result = program();
    let res = if result.is_ok() {
        0
    } else {
        println(&result.unwrap_err().msg);
        -1
    };
    print("heap count: ");
    println(&(*mem:heap_count()).to_string());
    res
}

fun program() -> Result<()> {
    println("Connecting...");
    let socket = TCP_Socket:connect("127.0.0.1", 8080)?;
    println("connected!");
    socket.send_text("hello!");
    println("done.");
    Result<()>:ok(())
}
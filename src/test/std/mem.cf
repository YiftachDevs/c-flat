import std/core.cf;

extern fun memcpy(dest_ptr: &(), src_ptr: &(), size: usize);
extern fun malloc(size: usize) -> &();
extern fun free(ptr: &());

mod mem {
    struct Manually_Drop<T> {
        value: T
    }

    fun copy<T>(dest_ptr: &T, src_ptr: &T) {
        memcpy(dest_ptr as &(), src_ptr as &(), T:mem_size());
    }

    fun copy_range<T>(dest_ptr: &T, src_ptr: &T, len: usize) {
        memcpy(dest_ptr as &(), src_ptr as &(), len * T:mem_size());
    }

    fun heap_alloc<T>(len: usize) -> &T {
        *heap_count() += 1;
        malloc(len * T:mem_size()) as &T
    }

    fun heap_free<T>(ptr: &T) {
        *heap_count() -= 1;
        free(ptr as &())
    }

    fun heap_count() -> &mut usize {
        static mut count: usize = 0;
        &mut count
    }
}
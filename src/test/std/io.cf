import std/core.cf;

extern fun getchar() -> char;
extern fun putchar(chr: char) -> char;
extern fun puts(c_str: &u8);

fun print(str: &[u8]) {
    puts(str.as_ref());
}

impl char {
    fun utf8_len(self) -> u64 {
        let num = self as u32;
        if num < 0x7F {
            1
        } else if num < 0x7FF {
            2
        } else if num < 0xFFFF {
            3
        } else {
            4
        }
    }
}

fun read() -> String {
    let mut input = String:new();
    loop {
        let ch = getchar();
        if ch == '\n' | ch == '\0' {
            break;
        }
        let mut idx: u64 = 0;
        while idx < ch.utf8_len() {
            let utf8_slice: u8 = 0;
            memcpy(&utf8_slice as &(), (&ch as u64 + idx) as &(), 1);
            input.push(utf8_slice);
            idx += 1;
        }
    }
    input
}
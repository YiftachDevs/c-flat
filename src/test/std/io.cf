import std/core.cf;
import std/mem.cf;
import std/heap.cf;

extern fun getchar() -> char;
extern fun putchar(chr: char) -> char;
extern fun puts(c_str: &char);

fun print(str: &[char]) {
    let mut null_terminated = String:from(str);
    null_terminated.push('\0');
    puts(null_terminated.as_ref());
}

impl char {
    fun utf8_len(self) -> usize {
        let num = self as u32;
        if num < 0x7F {
            1
        } else if num < 0x7FF {
            2
        } else if num < 0xFFFF {
            3
        } else {
            4
        }
    }
}

fun read() -> String {
    let mut input = String:new();
    loop {
        let ch = getchar();
        if ch == '\n' | ch == '\0' {
            break;
        }
        let mut idx: usize = 0;
        while idx < ch.utf8_len() {
            let utf8_slice: char = 0;
            mem:copy<char>(&utf8_slice, (&ch as usize + idx) as &char, 1);
            input.push(utf8_slice);
            idx += 1;
        }
    }
    input
}
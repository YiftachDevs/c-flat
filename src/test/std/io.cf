import std/core.cf;
import std/mem.cf;
import std/string.cf;

extern fun getchar() -> char;
extern fun putchar(chr: char) -> char;
extern fun puts(c_str: &char);
extern fun printf(c_str: &char);
extern fun system(cmd: &char) -> i32;

fun print(str: &[char]) {
    let mut string = String:from(str).null_terminate();
    puts(string.as_ref());
}

fun write(str: &[char]) {
    let mut string = String:from(str).null_terminate();
    printf(string.as_ref());
}

fun exec_cmd(str: &[char]) -> i32 {
    let mut string = String:from(str).null_terminate();
    system(string.as_ref())
}

fun read() -> String {
    let mut input = String:new();
    loop {
        let ch = getchar();
        if ch == '\n' | ch == '\0' {
            break;
        }
        input.push(ch);
    }
    input
}
import std/core.cf;
import std/mem.cf;
import std/iter.cf;

struct Box<T> {
    value_ref: &T
}

impl<T> Box<T> {
    fun new(value: T) -> Self {
        let value_ref = mem:heap_alloc<T>(1);
        mem:copy<T>(value_ref, &value);
        let man_drop = mem:Manually_Drop<T>{ value };
        Self{ value_ref }
    }

    fun as_ref(&self) -> &T {
        &**self
    }
}

impl<T> Deref<T> for Box<T> {
    fun deref(&self) -> &T { self.value_ref as &T }
    fun deref_mut(&mut self) -> &mut T { self.value_ref as &mut T }
}

impl<T> Drop for Box<T> {
    fun drop(&self) {
        self.value_ref.drop();
        mem:heap_free<T>(self.value_ref);
    }
}

struct Vec<T> {
    ptr: &T,
    len: usize,
    capacity: usize
}

impl<T> Vec<T> {
    fun new() -> Self {
        Self:with_capacity(4)
    }

    fun from(slice: &[T]) -> Self {
        let mut result = Self:new();
        result.extend_from_slice(slice);
        result
    }

    fun capacity(&self) -> usize { self.capacity }

    fun with_capacity(capacity: usize) -> Self {
        Self{ mem:heap_alloc<T>(capacity), 0, capacity }
    }

    fun reserve(&mut self, additional: usize) {
        let new_len = self.len + additional;
        if new_len > self.capacity {
            while new_len > self.capacity {
                self.capacity *= 2;
            }
            let new_ptr = mem:heap_alloc<T>(self.capacity);
            mem:copy_range<T>(new_ptr, self.ptr, self.len);
            mem:heap_free<T>(self.ptr);
            self.ptr = new_ptr;
        }
    }

    fun extend_from_slice(&mut self, slice: &[T]) {
        let mut idx: usize = 0;
        while idx < slice.len() {
            self.push(slice[idx]);
            idx += 1;
        }
    }

    fun extend(&mut self, other: Self) {
        self.extend_from_slice(&other);
    }

    fun push(&mut self, value: T) {
        self.reserve(1);
        mem:copy<T>((self.ptr as usize + self.len * T:mem_size()) as &T, &value);
        self.len += 1;
        let man_drop = mem:Manually_Drop<T>{ value };
    }

    fun pop(&mut self) {
        if self.len > 0 {
            self.len -= 1;
            self[self.len].drop();
        }
    }

    fun insert(&mut self, idx: usize, value: T) {
        let type_mem_size = T:mem_size();
        self.reserve(1);
        let insert_ptr = (self.ptr as usize + idx * type_mem_size) as &T;
        mem:copy_range<T>((insert_ptr as usize + type_mem_size) as &T, insert_ptr, self.len - idx);
        mem:copy<T>(insert_ptr, &value);
        self.len += 1;
        let man_drop = mem:Manually_Drop<T>{ value };
    }

    fun as_slice(&self) -> &[T] { [T]:from_raw_parts(self.ptr, self.len) }
    fun as_mut_slice(&mut self) -> &mut [T] { [T]:from_raw_parts(self.ptr, self.len) }
}

impl<T: Eq> Vec<T> {
    fun has(&self, value: T) -> bool {
        for item in self.iter() {
            if *item == value {
                return true;
            }
        }
        false
    }
}

impl<T> Drop for Vec<T> {
    fun drop(&self) {
        let mut idx: usize = 0;
        while idx < self.len() {
            self[idx].drop();
            idx += 1;
        }
        mem:heap_free<T>(self.ptr);
    }
}

impl<T> Deref<[T]> for Vec<T> {
    fun deref(&self) -> &[T] { self.as_slice() }
    fun deref_mut(&mut self) -> &mut [T] { self.as_mut_slice() }
}
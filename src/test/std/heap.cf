import std/core.cf;
import std/mem.cf;

struct Box<T> {
    value_ref: &T
}

impl<T> Box<T> {
    fun new(value: T) -> Self {
        let mem_size = T:mem_size();
        let value_ref = mem:heap_alloc<T>(mem_size);
        mem:copy<T>(value_ref, &value, mem_size);
        Self{ value_ref }
    }

    fun as_ref(&self) -> &T {
        &**self
    }
}

impl<T> Deref<T> for Box<T> {
    fun deref(&self) -> &T { self.value_ref as &T }
    fun deref_mut(&mut self) -> &mut T { self.value_ref as &mut T }
}

impl<T> Drop for Box<T> {
    fun drop(&self) {
        mem:heap_free<T>(self.value_ref);
    }
}

struct Vec<T> {
    ptr: &T,
    len: u64,
    capacity: u64
}

impl<T> Vec<T> {
    fun new() -> Self {
        let type_mem_size = T:mem_size();
        Self{ mem:heap_alloc<T>(4 * type_mem_size), 0, 4 }
    }

    fun from(slice: &[T]) -> Self {
        let mut vec = Self:new();
        let mut idx: u64 = 0;

        while idx < slice.len() {
            vec.push(slice[idx]);
            idx += 1;
        }
        vec
    }

    fun push(&mut self, value: T) {
        let type_mem_size = T:mem_size();
        if self.len == self.capacity {
            self.capacity *= 2;
            let ptr = mem:heap_alloc<T>(self.capacity * type_mem_size);
            mem:copy<T>(ptr, self.ptr, self.len * type_mem_size);
            mem:heap_free<T>(self.ptr);
            self.ptr = ptr as &T;
        }
        memcpy((self.ptr as u64 + self.len * type_mem_size) as &(), &value as &(), type_mem_size);
        self.len += 1;
        let man_drop = mem:Manually_Drop<T>{ value };
    }

    fun pop(&self) {
        if self.len > 0 {
            let v = self[self.len];
            self.len -= 1;
        }
    }
}

impl<T> Drop for Vec<T> {
    fun drop(&self) {
        let mut idx: u64 = 0;
        while idx < self.len() {
            self[idx].drop();
            idx += 1;
        }
        mem:heap_free<T>(self.ptr);
    }
}

impl<T> Deref<[T]> for Vec<T> {
    fun deref(&self) -> &[T] { [T]:from_raw_parts(self.ptr, self.len) }
    fun deref_mut(&mut self) -> &mut [T] { [T]:from_raw_parts(self.ptr, self.len) }
}

struct String {
    chars: Vec<u8>
}

impl String {
    fun new() -> Self {
        Self{ Vec<u8>:new() }
    }

    fun from(slice: &[u8]) -> Self {
        Self{ Vec<u8>:from(slice) }
    }
}

impl Deref<Vec<u8>> for String {
    fun deref(&self) -> &Vec<u8> { &self.chars }
    fun deref_mut(&mut self) -> &mut Vec<u8> { &mut self.chars }
}

impl [u8] {
    fun to_string(&self) -> String {
        String:from(self)
    }
}
fun main() {
    let vec = Vec_2<i32> { 4, 3 }.add(Vec_2<i32> { -3, 2 });
}

struct Vec_3<T: i32, f32> { x: T, y: T, z: T }
struct Wrapper<T> { value: T }

trait Add<OtherT> {
    fun add(self, other: OtherT) -> Self;
}

impl<T> Add<Vec_2<T>> for Vec_2<T> {
    fun add(self, other: Self) -> Self {
        Self { self.x + other.x, self.y + other.y }
    }
}
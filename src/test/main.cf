fun main() {
    let vec_2 = math.Vec_2<f32> { 0.4, 0.3 };
    vec_2.get_x();
}


mod math {
    struct Vec_2<T: f32> { x: T, y: T }

    impl<T> Vec_2<T> {
        fun get_x(self: Self) -> T {
            self.y
        }
    }

    impl<T: f32> Vec_2<T> {
        fun get_x(self: Self) -> T {
            self.x
        }
    }
}
import std/io.cf;
import std/math.cf;
import std/rng.cf;
import std/time.cf;
import pixel/game.cf;


fun main() -> usize {
    {
        let mut game = pixel:Game:new(Vec_2<usize>{ 32, 32 }, 16);

        for y in 0..32 {
            for x in 0..32 {
                game.frame.buffer[y * 32 + x] = ((x + y) % 8) as u8;
            }
        }

        @game_loop loop {
            game.update();

            for i in 0..32 * 32 {
                game.frame.buffer[i] = (game.frame.buffer[i] - 1) % 8;
            }

            for key_press in game.key_presses.iter() {
                if *key_press == 'q' {
                    break @game_loop;
                }
            }

            game.render();
        }
    };
    println("game over");
    0
}

fun debug_heap_count() {
    let heap_count = *mem:heap_count();
    println(&heap_count.to_string());
}

fun paint() {
    let mut dots = Vec<Vec_2<i32>>:new();
    let mut pos = Vec_2<i32>{ 12, 10 };
    @game_loop loop {
        while c_kbhit() {
            let input = c_getch();
            if input == 'q' {
                break @game_loop;
            }
            if input == 'p' & !dots.has(pos) {
                dots.push(pos);
            }
            pos.x += if input == 'd' { 1 } else if input == 'a' { -1 } else { 0 };
            pos.y += if input == 's' { 1 } else if input == 'w' { -1 } else { 0 };
        }
        print("\033[2J\033[H");
        for y in 0..32 {
            for x in 0..32 {
                let cur_pos = Vec_2<i32>{ x, y };
                let mut stamp = x == 0 | y == 0 | x == 31 | y == 31 | pos == cur_pos | dots.has(cur_pos);
                let chr = if stamp { '@' } else { ' ' };
                c_putchar(chr);
            }
            c_putchar('\n');
        }
        println(&dots.len().to_string());
        sleep(1.0 / 30.0);
    }
}

fun boo() {
    let mut arr = [0; 5];
    for i in 0..150 {
        arr[(0..5).rand()] += 1;
    }
    print(&arr.to_string());
    let vec = Vec<i32>:from(&[1, 124, 3]);
    let mut sum = 0;
    for i in 0..10 {
        sum += i.clamp(5, 5);
    }
    print("sum: ");
    print(&sum.to_string());
    print(&vec.to_string());
    print(&"bye!".to_string());
}
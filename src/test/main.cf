import std/io.cf;
import std/math.cf;
import std/rng.cf;
import std/time.cf;
import std/system.cf;
import game.cf;

fun main() -> usize {
    {
        loop {
            print("Enter file to read: ");
            let file_name = readln();
            let opt_file = File:open(&file_name);
            if opt_file.is_some() {
                let file = opt_file.unwrap();
                println(&file.read_text());
                break;
            } else {
                println("File doesn't exist, try again.");
            }
        }
    }
    println("game over");
    debug_heap_count();
    0
}

fun debug_heap_count() {
    let heap_count = *mem:heap_count();
    println(&heap_count.to_string());
}
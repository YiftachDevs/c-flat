import std/core.cf;
import std/io.cf;

fun main() -> usize {
    {
        let vec = Vec<i32>:from(&[1, 124, 3]);
        let mut sum = 0;
        for i in 0..10 {
            sum += i;
            if i == 40 {
                break;
            }
        }
        print("sum: ");
        print(&sum.to_string());
        print(&vec.to_string());
    };
    *mem:heap_count()
}
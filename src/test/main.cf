import std/core.cf;
import std/io.cf;
import std/math.cf;
import std/rng.cf;

fun main() -> usize {
    {        
        exec_cmd("stty -icanon -echo");
        let mut dots = Vec<Vec_2<i32>>:new();
        let mut pos = Vec_2<i32>{ 12, 10 };
        loop {
            let input = getchar();
            if input == 'q' {
                break;
            }
            if input == 'p' & !dots.has(pos) {
                dots.push(pos);
            }
            pos.x += if input == 'd' { 1 } else if input == 'a' { -1 } else { 0 };
            pos.y += if input == 's' { 1 } else if input == 'w' { -1 } else { 0 };
            exec_cmd("clear");
            for y in 0..32 {
                for x in 0..32 {
                    let cur_pos = Vec_2<i32>{ x, y };
                    let mut stamp = x == 0 | y == 0 | x == 31 | y == 31 | pos == cur_pos;
                    for dot in dots.iter() {
                        if *dot == cur_pos {
                            stamp = true;
                            break;
                        }
                    }
                    let chr = if stamp { '@' } else { ' ' };
                    putchar(chr);
                }
                putchar('\n');
            }
            print(&dots.len().to_string());
        }
    };
    *mem:heap_count()
}

fun foo() {
    foo(3 + 2);
    let mut arr = [0, 0, 0, 0, 0];
    for i in 0..150 {
        arr[rng:gen<usize>(0..5)] += 1;
    }
    print(&arr.to_string());
    let vec = Vec<i32>:from(&[1, 124, 3]);
    let mut sum = 0;
    for i in 0..10 {
        sum += i.clamp(5, 5);
    }
    print("sum: ");
    print(&sum.to_string());
    print(&vec.to_string());
    print(&"bye!".to_string());
}
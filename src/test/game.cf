import std/io.cf;
import std/math.cf;
import std/rng.cf;
import std/time.cf;
import pixel/pixel.cf;

struct Particle {
    pos: Vec_2<f64>,
    size: f64,
    speed: f64,
    new_speed: f64,
    offset: f64,
    color: pixel:Color
}

impl Particle {
    fun spawn(screen_size: Vec_2<usize>) -> Self {
        let speed = 0.25 + (0.0..5.0).rand();
        Self{ Vec_2<f64>{ (0.0..screen_size.x as f64).rand(), (0.0..screen_size.y as f64).rand() }, (1.0..2.4).rand(), speed, speed, (0.0..1.0).rand(), rand_color() }
    }

    fun spawn_at(pos: Vec_2<f64>, color: pixel:Color) -> Self {
        let speed = 0.25 + (0.0..5.0).rand();
        Self{ pos, (3.0..5.4).rand(), speed, speed, (0.0..1.0).rand(), color }
    }

    fun update(&mut self, screen_size: Vec_2<usize>) {
        self.speed = self.speed.lerp(self.new_speed, 0.05);
        self.pos.x += self.speed;
        self.pos.y += self.offset.sin();
        self.offset += 0.05.min(self.speed / 46.0);
        if self.pos.x > screen_size.x as f64 + 4.0 {
            self.pos.x = -4.0;
            self.pos.y = (0.0..screen_size.y as f64).rand();
        } else if self.pos.x < -4.0 {
            self.pos.x = screen_size.x as f64 + 4.0;
            self.pos.y = (0.0..screen_size.y as f64).rand();
        }
    }

    fun render(&self, game: &mut pixel:Game) {
        game.draw_rect(Vec_2<i32>{ self.pos.x as i32, self.pos.y as i32 }, Vec_2<usize>{ self.size as usize, self.size as usize }, self.color );
    }
}

struct Player {
    texture: pixel:Texture,
    pos: Vec_2<f64>,
    velocity: Vec_2<f64>,
    anim_vec: Vec_2<usize>
}

impl Player {
    fun new(game: &mut pixel:Game) -> Self {
        let texture = game.load_texture("res/slime.png");
        Self{ texture, Vec_2<f64>{ 0.0, 0.0 }, Vec_2<f64>{ 0.0, 0.0 }, Vec_2<usize>{ 0, 0 } }
    }

    fun update(&mut self, game: &mut pixel:Game, particles: &mut Vec<Particle>) {
        let prev_pos = self.pos;
        self.velocity.x = if game.is_key_down('D') { 1.0 } else if game.is_key_down('A') { -1.0 } else { 0.0 };
        self.velocity.y = if game.is_key_down('S') { 4.0 } else if game.is_key_down('W') { -4.0 } else { self.velocity.y };
        self.velocity.y += 0.1;
        self.pos = self.pos + self.velocity;
        let floor = game.pixel_frame_size.y as f64 - 32.0;
        if self.pos.y >= floor {
            self.pos.y = floor;
            self.velocity.y = 0.0;
        }
        self.anim_vec.x = (self.anim_vec.x + 1) % 30;

        if game.is_key_down('P') {
            particles.push(Particle:spawn_at(self.pos, rand_color()));
            self.anim_vec.y = 3 * 3;
        } else {
            self.anim_vec.y = 2 * 3;
        }
    }

    fun render(&self, game: &mut pixel:Game) {
        game.draw_animation_texture(self.texture, self.pos.as<i32>(), self.anim_vec / 3, Vec_2<usize>{ 32, 32 });
    }
}

fun rand_color() -> pixel:Color {
    ((200..256).rand() |
    ((200..256).rand() << 8) |
    ((200..256).rand() << 16) |
    255 << 24) as pixel:Color
}

fun game() {
    let mut game = pixel:Game:new("C Flat Compiler", Vec_2<usize>{ 320, 180 }, 3);

    let mut player = Player:new(&mut game);
    
    let mut particles = Vec<Particle>:new();
    for i in 0..5 {
        particles.push(Particle:spawn(game.pixel_frame_size));
    }

    while !game.should_close() {
        game.update();
        
        if game.is_mouse_pressed(0) {
            particles.push(Particle:spawn_at(game.mouse_pos().as<f64>(), rand_color()))
        }
        if game.is_mouse_pressed(2) {
            for particle in particles.iter_mut() {
                particle.new_speed = -particle.speed;
            } 
        }
        if game.is_key_down('F') {
            for particle in particles.iter_mut() {
                particle.new_speed *= 1.01;
            }
        }

        player.update(&mut game, &mut particles);
        
        for particle in particles.iter_mut() {
            particle.update(game.pixel_frame_size);
        }

        game.begin_draw();
        game.clear_background();
        player.render(&mut game);
        for particle in particles.iter_mut() {
            particle.render(&mut game);
        }
        game.end_draw();
    }

    game.close();
}
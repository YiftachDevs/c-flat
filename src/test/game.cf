import std/io.cf;
import std/math.cf;
import std/rng.cf;
import std/time.cf;
import pixel/pixel.cf;

struct Particle {
    pos: Vec_2<f64>,
    size: f64,
    speed: f64,
    new_speed: f64,
    offset: f64,
    color: pixel:Color
}

impl Particle {
    fun spawn(screen_size: Vec_2<usize>) -> Self {
        let speed = 0.25 + (0.0..5.0).rand();
        Self{ Vec_2<f64>{ (0.0..screen_size.x as f64).rand(), (0.0..screen_size.y as f64).rand() }, (1.0..2.4).rand(), speed, speed, (0.0..1.0).rand(), rand_color() }
    }

    fun spawn_at(pos: Vec_2<f64>, color: pixel:Color) -> Self {
        let speed = 0.25 + (0.0..5.0).rand();
        Self{ pos, (3.0..5.4).rand(), speed, speed, (0.0..1.0).rand(), color }
    }

    fun update(&mut self, screen_size: Vec_2<usize>) {
        self.speed = self.speed.lerp(self.new_speed, 0.05);
        self.pos.x += self.speed;
        self.pos.y += self.offset.sin();
        self.offset += 0.05.min(self.speed / 46.0);
        if self.pos.x > screen_size.x as f64 + 4.0 {
            self.pos.x = -4.0;
            self.pos.y = (0.0..screen_size.y as f64).rand();
        } else if self.pos.x < -4.0 {
            self.pos.x = screen_size.x as f64 + 4.0;
            self.pos.y = (0.0..screen_size.y as f64).rand();
        }
    }

    fun render(&self, game: &mut pixel:Game) {
        game.draw_rect(Vec_2<i32>{ self.pos.x as i32, self.pos.y as i32 }, Vec_2<usize>{ self.size as usize, self.size as usize }, self.color );
    }
}

fun rand_color() -> pixel:Color {
    ((0..256).rand() |
    ((0..256).rand() << 8) |
    ((0..256).rand() << 16) |
    255 << 24) as pixel:Color
}

fun game() {
    let mut game = pixel:Game:new("My First Game", Vec_2<usize>{ 320, 180 }, 6);

    let texture = game.load_texture("res/image.png");
    let mut particles = Vec<Particle>:new();
    for i in 0..50 {
        particles.push(Particle:spawn(game.pixel_frame_size));
    }

    while !game.should_close() {
        if game.is_mouse_pressed(0) {
            particles.push(Particle:spawn_at(game.mouse_pos().as<f64>(), rand_color()))
        }
        if game.is_mouse_pressed(2) {
            for particle in particles.iter_mut() {
                particle.new_speed = -particle.speed;
            } 
        }
        
        for particle in particles.iter_mut() {
            particle.update(game.pixel_frame_size);
        }

        game.begin_draw();
        game.clear_background();
        for particle in particles.iter_mut() {
            particle.render(&mut game);
        }
        if game.is_mouse_down(0) {
            game.draw_text("Mouse Down", Vec_2<i32>{ 10, 10 }, 1, 0xFFFFFFFF);
        }
        // game.draw_texture(texture, Vec_2<usize>{ (-10..11).rand(), (-10..11).rand() }.as<i32>() );
        game.end_draw();
    }

    game.close();
}